{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Ares",
  "version": "1.0.0",
  "identifier": "com.vikasgautam.devkit",
  "build": {
    "frontendDist": "../out",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "Ares",
        "width": 1280,
        "height": 820,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/64x64.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15",
      "signingIdentity": null
    },
    "shortDescription": "Unified dev workspace — DSA, prompts, planner, finance",
    "longDescription": "DevKit is an offline-first desktop app for developers combining DSA tracking, AI prompt management, weekly planning, and personal finance in one place.",
    "copyright": "© 2026 Vikas Gautam"
  }
}